      <column caption='Living in Community Quartile' datatype='string' name='[Calculation_6820349809039835136]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED : PERCENTILE([index_rel_communal_living], 0.25) } &gt;= [index_rel_communal_living] THEN&#10;    &quot;Q1&quot;&#10;ELSEIF { FIXED : PERCENTILE([index_rel_communal_living], 0.5) } &gt;= [index_rel_communal_living] THEN&#10;    &quot;Q2&quot;&#10;ELSEIF { FIXED : PERCENTILE([index_rel_communal_living], 0.75) } &gt;= [index_rel_communal_living] THEN&#10;    &quot;Q3&quot;&#10;ELSE&#10;    &quot;Q4&quot;&#10;END' />
